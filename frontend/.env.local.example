# ─── ÉCLAT Frontend — Environment Variables ────────────────────────────────
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and NEVER committed to the repository.

# Laravel API URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Site URL (used in sitemap, canonical URLs, OG meta)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
